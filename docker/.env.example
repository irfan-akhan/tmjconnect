# ─── Docker Compose environment file ────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_this_strong_password

# ─── JWT Secrets (min 64 chars each) ────────────────────────────────────────────
JWT_SECRET=change_me_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_at_least_64_chars_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# ─── MFA Encryption Key (64 hex chars = 32 bytes) ────────────────────────────────
MFA_ENCRYPTION_KEY=change_me_32_byte_hex_zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz

# ─── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://provider.tmjconnect.com,https://admin.tmjconnect.com

# ─── SPA build-time API base URL ─────────────────────────────────────────────────
# Baked into the provider/admin bundles by vite at build time. For the default
# nginx same-origin setup, /api/v1 is correct. Change only if the SPA lives on
# a different origin than the API.
PROVIDER_API_BASE_URL=/api/v1
ADMIN_API_BASE_URL=/api/v1

# ─── Email ───────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ─── SMS ─────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# ─── Push (Firebase) ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ─── App URLs ────────────────────────────────────────────────────────────────────
APP_URL=https://app.tmjconnect.com
API_URL=https://api.tmjconnect.com

# ─── Error tracking ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/project-id
