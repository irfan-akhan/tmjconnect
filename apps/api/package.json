    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.29.3",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "otpauth": "^9.2.3",
