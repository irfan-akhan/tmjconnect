# ──────────────────────────────────────────────────────────────────────────────
# Production VPS environment
#
# Deploys to:  /etc/tmjconnect/api-prod.env  (chmod 640, owner root:tmjconnect-prod)
# Loaded by:   tmjconnect-api-prod.service (EnvironmentFile=)
#
# Hard rules:
#   - All secrets generated fresh; NEVER reused from dev/test
#   - Swagger UI OFF (no spec exposure on prod surface)
#   - LOG_LEVEL=info (debug logs in prod inflate cost + leak structure)
#   - Real Resend/Twilio/Firebase credentials with signed BAAs
#   - Sentry DSN is the production project (not test)
#
# Generate fresh secrets:
#   openssl rand -base64 48     # JWT_SECRET, JWT_REFRESH_SECRET
#   openssl rand -hex 32        # MFA_ENCRYPTION_KEY
#   openssl rand -base64 48     # BACKUP_PASSPHRASE
# ──────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production
PORT=3000

# ─── Database (production DB on the shared host) ─────────────────────────────
DATABASE_URL=postgresql://tmjconnect_api:CHANGE_ME@localhost:5432/tmjconnect

# ─── JWT (DO NOT reuse from dev or test) ─────────────────────────────────────
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_base64_48
# Set to the previous JWT_SECRET during a rotation window — see env.ts comment.
# JWT_SECRET_PREVIOUS=

# ─── MFA encryption (DO NOT reuse — rotation re-encrypts all stored secrets) ─
MFA_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://provider.tmjconnect.com,https://admin.tmjconnect.com

# ─── External services — production credentials with signed BAAs ─────────────
# Resend prod API key (NOT the test/sandbox one)
RESEND_API_KEY=re_CHANGE_ME
# Twilio production credentials
TWILIO_ACCOUNT_SID=ACCHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+1CHANGE_ME
# Production Firebase project
FIREBASE_PROJECT_ID=tmjconnect-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-prod@tmjconnect-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# ─── Storage ─────────────────────────────────────────────────────────────────
# Pilot: local disk. Migrate to s3 once user count grows past the pilot tier.
STORAGE_DRIVER=local
UPLOAD_DIR=/var/lib/tmjconnect-prod/uploads
# When STORAGE_DRIVER=s3, fill these:
# S3_BUCKET=tmjconnect-uploads
# S3_REGION=us-east-1
# CLOUDFRONT_URL=https://CHANGE_ME.cloudfront.net

# ─── App URLs (production subdomains) ────────────────────────────────────────
APP_URL=https://provider.tmjconnect.com
API_URL=https://api.tmjconnect.com

# ─── Sentry (production project — SEPARATE from test) ────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── API docs (DISABLED on prod) ─────────────────────────────────────────────
ENABLE_DOCS=false

# ─── Backup encryption ───────────────────────────────────────────────────────
# Separate passphrase from test. Store in your password manager — restore is
# impossible without it. Stored on the host at /opt/tmjconnect/.backup_passphrase
# (chmod 600); this var is reserved for backup tooling that prefers an env var.
BACKUP_PASSPHRASE=CHANGE_ME
