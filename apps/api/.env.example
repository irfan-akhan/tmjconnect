# ─── Server ──────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3000                     # API server port

# ─── Database (required — startup fails without this) ─────────────────────────────
# Must include ?sslmode=require for encrypted API→DB connections in production.
# In local dev use: postgresql://tmjconnect:dev_password@localhost:5432/tmjconnect
DATABASE_URL=postgresql://tmjconnect:changeme@localhost:5432/tmjconnect?sslmode=disable

# ─── JWT Secrets (required — minimum 64 random characters each) ───────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_at_least_64_chars_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_at_least_64_chars_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# ─── MFA Encryption Key (required — 32-byte hex = 64 chars) ──────────────────────
# Encrypts TOTP secrets at rest using AES-256-GCM.
# Generate: openssl rand -hex 32
MFA_ENCRYPTION_KEY=change_me_32_byte_hex_zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz

# ─── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Include the protocol (https://).
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173,http://localhost:5174

# ─── Email — Resend (optional in dev, required in production) ─────────────────────
# If absent: emails are logged to console in dev. Startup fails in production.
# Get your key at: https://resend.com
RESEND_API_KEY=re_your_key_here

# ─── SMS — Twilio (optional in dev, required if SMS MFA enabled) ─────────────────
# If absent: SMS codes are logged to console in dev. Startup fails in production.
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ─── Push Notifications — Firebase FCM ────────────────────────────────────────────
# If absent: push notifications are no-ops in dev. Startup fails in production.
# Download service account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Private key: the "private_key" field from service account JSON.
# Replace actual newlines with \n when pasting into .env file.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── File Storage ────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local          # local | s3
UPLOAD_DIR=./uploads          # Used when STORAGE_DRIVER=local

# AWS S3 (only required when STORAGE_DRIVER=s3)
S3_BUCKET=tmjconnect-uploads
S3_REGION=us-east-1
CLOUDFRONT_URL=https://dxxxxxxxxxxxxx.cloudfront.net

# ─── App URLs ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8081  # Patient mobile app URL (used in email links)
API_URL=http://localhost:3000  # API base URL (used in file URL construction)

# ─── Error Tracking — Sentry ─────────────────────────────────────────────────────
# If absent: errors are only logged locally via pino.
# IMPORTANT: Configure PII scrubbing beforeSend hook before using Sentry with real data.
SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ─── Logging ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info                # debug | info | warn | error. Use debug for SQL query logging in dev.

# ─── Backup (pilot VPS only) ─────────────────────────────────────────────────────
# GPG symmetric passphrase for encrypting pg_dump backups.
# Store this separately from .env in production (e.g. in a secrets vault).
BACKUP_PASSPHRASE=change_me_strong_passphrase_here
