# ──────────────────────────────────────────────────────────────────────────────
# Test VPS environment
#
# Deploys to:  /etc/tmjconnect/api-test.env  (chmod 640, owner root:tmjconnect-test)
# Loaded by:   tmjconnect-api-test.service (EnvironmentFile=)
#
# Behavior parity with production: NODE_ENV=production, real services, strict
# secret validation. Differences ONLY:
#   - Different DB (`tmjconnect_test`) + role (`tmjconnect_api_test`)
#   - APP_ENV=test (Sentry tag, log enrichment)
#   - LOG_LEVEL=debug
#   - ENABLE_DOCS=true (Swagger UI mounted at /docs)
#   - Different port (3001) so it can run alongside prod on the same VPS
#   - Test subdomains (api.test.tmjconnect.com etc.)
#   - Separate Sentry project (different DSN)
#   - Resend/Twilio in TEST MODE (sandbox creds, NOT real PHI delivery)
#
# Generate fresh secrets — NEVER copy from dev or prod:
#   openssl rand -base64 48     # JWT_SECRET, JWT_REFRESH_SECRET
#   openssl rand -hex 32        # MFA_ENCRYPTION_KEY
# ──────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=test
PORT=3001

# ─── Database (test DB on shared host — separate role from prod) ─────────────
DATABASE_URL=postgresql://tmjconnect_api_test:CHANGE_ME@localhost:5432/tmjconnect_test

# ─── JWT (DO NOT reuse from dev or prod) ─────────────────────────────────────
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_openssl_rand_base64_48

# ─── MFA encryption (DO NOT reuse from dev or prod) ──────────────────────────
MFA_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://provider.test.tmjconnect.com,https://admin.test.tmjconnect.com

# ─── External services — use SANDBOX/TEST credentials only ───────────────────
# Resend test mode: https://resend.com/docs/dashboard/api-keys/introduction
RESEND_API_KEY=re_test_CHANGE_ME
# Twilio test credentials: Console → Settings → API keys
TWILIO_ACCOUNT_SID=ACtest_CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+15005550006
# Separate Firebase project for test push notifications
FIREBASE_PROJECT_ID=tmjconnect-test
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-test@tmjconnect-test.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# ─── Storage (separate dir from prod on the shared host) ─────────────────────
STORAGE_DRIVER=local
UPLOAD_DIR=/var/lib/tmjconnect-test/uploads

# ─── App URLs (test subdomains) ──────────────────────────────────────────────
APP_URL=https://provider.test.tmjconnect.com
API_URL=https://api.test.tmjconnect.com

# ─── Sentry (SEPARATE project from prod so test errors don't pollute prod) ───
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME

# ─── Logging (verbose for debugging) ─────────────────────────────────────────
LOG_LEVEL=debug

# ─── API docs (Swagger UI enabled on test for interactive verification) ──────
ENABLE_DOCS=true

# ─── Backup encryption (separate passphrase from prod) ───────────────────────
BACKUP_PASSPHRASE=CHANGE_ME
