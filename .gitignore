# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Environment files — never commit secrets.
# `.env.*.example` templates ARE committed; the unsuffixed `.env.development`
# (etc.) are populated locally and stay on disk only.
.env
.env.local
.env.development
.env.test
.env.production
.env.development.local
.env.test.local
.env.production.local
# Re-allow the templates (they are the only safe versions to commit)
!.env.example
!.env.development.example
!.env.test.example
!.env.production.example

# Drizzle generated (keep migrations, ignore meta snapshots in .gitignore if desired)
# drizzle/migrations/  ← do NOT ignore — migrations must be committed
drizzle/meta/          # Drizzle internal snapshot files (not needed in repo)

# Uploads (pilot: local disk storage)
apps/api/uploads/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json

# Test coverage
coverage/
.nyc_output/

# TypeScript incremental build info
*.tsbuildinfo

# Firebase service account (contains private key — never commit)
firebase-service-account.json
*service-account*.json

# Local Netlify folder
.netlify
