# Shared dev image for api / provider / admin.
#
# The compose dev stack bind-mounts the repo at /app and uses a named volume
# for /app/node_modules (so the host's macOS node_modules doesn't leak into
# the Linux container). This image exists only to provide a pre-populated
# node_modules + toolchain; the actual source at runtime comes from the
# bind mount.
#
# Each service overrides `command:` to run its own `npm run dev` target.

FROM node:20-alpine

# git — some npm deps resolve git URLs during install.
# libc6-compat — needed by some native modules on alpine.
# wget — used by healthchecks.
RUN apk add --no-cache git libc6-compat wget

WORKDIR /app

# Copy every workspace manifest so `npm install --workspaces` resolves the
# full dependency graph. Source files are NOT copied — they'll be bind-mounted
# at runtime, which keeps edits on the host instantly visible in the container.
COPY package.json package-lock.json* ./
COPY tsconfig.base.json ./
COPY packages/shared/package.json ./packages/shared/
COPY apps/api/package.json ./apps/api/
COPY apps/provider/package.json ./apps/provider/
COPY apps/admin/package.json ./apps/admin/

RUN npm install --workspaces --include-workspace-root

# Shared package must be built at least once before dev servers start — the
# API imports `@tmjconnect/shared` as a compiled package. The dev-compose
# `api` service re-runs this in its entrypoint to pick up shared-schema edits.
COPY packages/shared/ ./packages/shared/
RUN npm run build --workspace=packages/shared

# Default is a no-op — compose services override with their own command.
CMD ["node", "--version"]
