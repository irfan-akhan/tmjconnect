# Node modules — always install fresh inside the container (host has macOS
# binaries that would break Linux images).
**/node_modules

# Build artifacts — re-built inside the container.
**/dist
**/build
**/.next
**/coverage

# Local env files — secrets stay out of image layers. Compose injects via
# `env_file:` / `environment:`.
**/.env
**/.env.local
**/.env.*.local

# Test + misc output.
**/*.log
**/.DS_Store
**/.idea
**/.vscode
**/.cache

# Git metadata.
.git
.gitignore
.github

# Docker files don't belong inside images.
docker/
Dockerfile*
**/Dockerfile*
.dockerignore

# Docs + markdown — not needed at runtime.
docs/
*.md
!packages/**/README.md

# Tests — production images don't ship with them.
apps/*/tests/
apps/*/*.test.ts
apps/*/*.test.tsx

# Bundle analyzer output.
**/stats.html
